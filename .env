# Jarvis Configuration
# Environment variables for Jarvis Personal AI Assistant

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=main.py

# Server Configuration
HOST=127.0.0.1
PORT=5000

# Speech Recognition
SPEECH_LANGUAGE=tr-TR
SPEECH_TIMEOUT=10

# Text-to-Speech
TTS_RATE=150
TTS_VOLUME=0.9

# Database (if needed for future updates)
DATABASE_URL=sqlite:///jarvis.db

# API Keys (add your API keys here if needed)
# OPENAI_API_KEY=your_api_key_here
# GOOGLE_API_KEY=your_api_key_here

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/jarvis.log
